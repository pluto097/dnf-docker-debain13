[client]
port		= 3306
socket		= /var/run/mysqld/mysqld.sock
default-character-set=latin1

[mysqld]
port		= 3306
socket		= /var/run/mysqld/mysqld.sock
datadir = /var/lib/mysql
user = mysql
server-id	= 1
skip-external-locking
skip-name-resolve
skip_symbolic_links = yes

# 基础字符集配置 - 保持原始DNF设计
character-set-server = latin1
collation-server = latin1_swedish_ci

# ========== 连接管理优化 ==========
max_connections = 1000
max_connect_errors = 1000
table_open_cache = 512
open_files_limit = 65535
net_buffer_length = 16K
max_allowed_packet = 64M

# ========== 内存分配优化 ==========
# MyISAM键缓存 - DNF大量使用MyISAM表
key_buffer_size = 32M
# 排序缓冲 - 增加大小提高排序性能
sort_buffer_size = 2M
# 顺序读缓冲
read_buffer_size = 512K
# 随机读缓冲
read_rnd_buffer_size = 1M
# MyISAM排序修复缓存
myisam_sort_buffer_size = 16M
# 临时表大小 - 防止磁盘临时表
tmp_table_size = 32M
max_heap_table_size = 32M

# ========== InnoDB优化 ==========
# InnoDB缓冲池 - 建议设置为可用内存的50-70%，这里保守设置
innodb_buffer_pool_size = 128M
# 关闭严格模式 - 保持兼容性，允许旧的DEFAULT ''语法
innodb_strict_mode = OFF
# 日志文件大小 - 提高写入性能
innodb_log_file_size = 64M
innodb_log_buffer_size = 8M
# 刷新日志策略 - 平衡性能和安全
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT

# ========== 查询缓存优化 ==========
# MySQL 5.7默认开启，DNF服务器读多写少可受益
query_cache_type = 1
query_cache_size = 16M
query_cache_limit = 2M

# ========== SQL模式兼容性配置 ==========
# 保持与MySQL 5.6兼容，避免严格模式导致默认值问题
# NO_ZERO_IN_DATE和NO_ZERO_DATE会导致DNF数据导入失败
sql_mode=NO_AUTO_VALUE_ON_ZERO,NO_ENGINE_SUBSTITUTION,NO_ZERO_IN_DATE,NO_ZERO_DATE

# ========== 日志配置 ==========
# 错误日志
log-error=/var/log/mysqld.log
# 慢查询日志 - 可用于性能分析，默认关闭需要时开启
#slow_query_log=1
#slow_query_log_file=/var/log/mysql-slow.log
#long_query_time=2

# ========== 安全配置 ==========
# 禁止本地文件访问，提高安全性
local-infile=0
# 符号链接保护
symbolic-links=0

[mysqld_safe]
log-error=/var/log/mysqld.log
pid-file=/var/run/mysqld/mysqld.pid
open-files-limit = 8192

[mysqldump]
quick
max_allowed_packet = 64M

[mysql]
no-auto-rehash
default-character-set=latin1

[myisamchk]
key_buffer_size = 64M
sort_buffer_size = 32M
read_buffer = 8M
write_buffer = 8M

[mysqlhotcopy]
interactive-timeout
